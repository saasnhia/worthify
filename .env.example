# ============================================
# FinPilote - Variables d'environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs

# Supabase Configuration
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mistral AI (LLM France RGPD — mistral-small-latest)
MISTRAL_API_KEY=

# Resend (emails de rappel paiement) → resend.com — plan gratuit 3000 emails/mois
# Obtenir une clé : https://resend.com/api-keys
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cron job secret
CRON_SECRET=

# ============================================
# APIs GOUVERNEMENTALES FRANÇAISES
# ============================================

# API Sirene INSEE (portail-api.insee.fr)
INSEE_API_KEY=

# API Pappers (scoring risque fournisseurs)
# Obtenir un token : https://www.pappers.fr/api
PAPPERS_API_TOKEN=

# API VIES (pas de token requis - API publique UE)

# ============================================
# n8n — Automatisation workflows cabinets
# ============================================
# Démarrer n8n : docker run -it --rm -p 5678:5678 n8nio/n8n
# Documentation : https://docs.n8n.io
N8N_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=finsoft_n8n_secret_2026
N8N_API_KEY=

# ============================================
# Intégrations ERP — Cegid Loop + Sage 50
# ============================================

# Supabase service role (requis pour les crons multi-cabinets)
SUPABASE_SERVICE_ROLE_KEY=

# Chiffrement AES-256-GCM des tokens OAuth au repos
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=

# Cegid Loop OAuth2 — https://developers.cegid.com
CEGID_CLIENT_ID=
CEGID_CLIENT_SECRET=
CEGID_REDIRECT_URI=https://finpilote.vercel.app/api/integrations/cegid/callback

# Chift (connecteur Sage 50) — https://app.chift.eu
CHIFT_API_KEY=
CHIFT_CONSUMER_ID=

# ============================================
# Stripe — Clés principales
# ============================================
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Anciens Price IDs (rétrocompatibilité — 3 plans legacy)
STRIPE_PRICE_STARTER=price_xxxx
STRIPE_PRICE_PRO=price_xxxx
STRIPE_PRICE_CABINET=price_xxxx

# ============================================
# Stripe — Plans par profil (nouveaux)
# ============================================
# Indépendant
STRIPE_STARTER_MONTHLY_ID=
STRIPE_STARTER_ANNUAL_ID=
STRIPE_PRO_INDEP_MONTHLY_ID=
STRIPE_PRO_INDEP_ANNUAL_ID=
STRIPE_PREMIUM_INDEP_MONTHLY_ID=
STRIPE_PREMIUM_INDEP_ANNUAL_ID=

# TPE (1-5 utilisateurs)
STRIPE_PRO_TPE_MONTHLY_ID=
STRIPE_PRO_TPE_ANNUAL_ID=
STRIPE_PREMIUM_TPE_MONTHLY_ID=
STRIPE_PREMIUM_TPE_ANNUAL_ID=

# PME (6-15 utilisateurs)
STRIPE_PRO_PME_MONTHLY_ID=
STRIPE_PRO_PME_ANNUAL_ID=
STRIPE_PREMIUM_PME_MONTHLY_ID=
STRIPE_PREMIUM_PME_ANNUAL_ID=

# Cabinet (experts-comptables)
STRIPE_CABINET_PRO_MONTHLY_ID=
STRIPE_CABINET_PRO_ANNUAL_ID=
STRIPE_CABINET_PREMIUM_MONTHLY_ID=
STRIPE_CABINET_PREMIUM_ANNUAL_ID=

# ============================================
# Contrôle d'accès abonnement
# ============================================
# DÉVELOPPEMENT UNIQUEMENT — ne jamais mettre sur Vercel prod
# Mettre dans .env.local pour bypasser le check subscription
# BYPASS_SUBSCRIPTION_CHECK=true
