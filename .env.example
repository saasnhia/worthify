# ============================================
# Worthify - Variables d'environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs

# Supabase Configuration
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mistral AI (LLM France RGPD — mistral-small-latest)
MISTRAL_API_KEY=

# Resend (emails de rappel paiement) → resend.com — plan gratuit 3000 emails/mois
# Obtenir une clé : https://resend.com/api-keys
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cron job secret
CRON_SECRET=

# ============================================
# APIs GOUVERNEMENTALES FRANÇAISES
# ============================================

# API Sirene INSEE (portail-api.insee.fr)
INSEE_API_KEY=

# API Pappers (scoring risque fournisseurs)
# Obtenir un token : https://www.pappers.fr/api
PAPPERS_API_TOKEN=

# API VIES (pas de token requis - API publique UE)

# ============================================
# n8n — Automatisation workflows cabinets
# ============================================
# Démarrer n8n : docker run -it --rm -p 5678:5678 n8nio/n8n
# Documentation : https://docs.n8n.io
N8N_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=worthify_n8n_secret_2026
N8N_API_KEY=

# ============================================
# Intégrations ERP — Cegid Loop + Sage 50
# ============================================

# Supabase service role (requis pour les crons multi-cabinets)
SUPABASE_SERVICE_ROLE_KEY=

# Chiffrement AES-256-GCM des tokens OAuth au repos
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=

# Cegid Loop OAuth2 — https://developers.cegid.com
CEGID_CLIENT_ID=
CEGID_CLIENT_SECRET=
CEGID_REDIRECT_URI=https://worthify.vercel.app/api/integrations/cegid/callback

# Chift (connecteur Sage 50) — https://app.chift.eu
CHIFT_API_KEY=
CHIFT_CONSUMER_ID=

# ============================================
# App URL (utilisé pour les redirections auth)
# ============================================
NEXT_PUBLIC_APP_URL=https://worthify.vercel.app

# ============================================
# Stripe — Clés principales
# ============================================
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ============================================
# Stripe — Price IDs par plan (correspondant à plans.ts)
# ============================================
# Starter (gratuit)
STRIPE_STARTER_MONTHLY=
STRIPE_STARTER_ANNUAL=

# Indépendant
STRIPE_BASIQUE_INDEP_MONTHLY=
STRIPE_BASIQUE_INDEP_ANNUAL=
STRIPE_ESSENTIEL_INDEP_MONTHLY=
STRIPE_ESSENTIEL_INDEP_ANNUAL=
STRIPE_PREMIUM_INDEP_MONTHLY=
STRIPE_PREMIUM_INDEP_ANNUAL=

# TPE (1-5 utilisateurs)
STRIPE_BASIQUE_TPE_MONTHLY=
STRIPE_BASIQUE_TPE_ANNUAL=
STRIPE_ESSENTIEL_TPE_MONTHLY=
STRIPE_ESSENTIEL_TPE_ANNUAL=
STRIPE_PREMIUM_TPE_MONTHLY=
STRIPE_PREMIUM_TPE_ANNUAL=

# PME (6-15 utilisateurs)
STRIPE_BASIQUE_PME_MONTHLY=
STRIPE_BASIQUE_PME_ANNUAL=
STRIPE_ESSENTIEL_PME_MONTHLY=
STRIPE_ESSENTIEL_PME_ANNUAL=
STRIPE_PREMIUM_PME_MONTHLY=
STRIPE_PREMIUM_PME_ANNUAL=

# Cabinet (experts-comptables)
STRIPE_CABINET_ESSENTIEL_MONTHLY=
STRIPE_CABINET_ESSENTIEL_ANNUAL=
STRIPE_CABINET_PREMIUM_MONTHLY=
STRIPE_CABINET_PREMIUM_ANNUAL=

# ============================================
# Contrôle d'accès abonnement
# ============================================
# DÉVELOPPEMENT UNIQUEMENT — ne jamais mettre sur Vercel prod
# Mettre dans .env.local pour bypasser le check subscription
# BYPASS_SUBSCRIPTION_CHECK=true
